SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-key
ESCROW_ENCRYPTION_KEY=your-32-byte-hex-encryption-key
BAGS_API_KEY=your-bags-api-key
BAGS_PARTNER_WALLET=your-bags-partner-wallet-public-key
BAGS_PARTNER_CONFIG=your-bags-partner-config-public-key
POLL_INTERVAL_MS=30000
# PumpPortal Lightning API (Pump.fun launch path).
# Generate the wallet + key at https://pumpportal.fun/trading-api/setup/
# The private key is used by the executor to sweep dev-buy tokens and
# residual SOL from the custodial wallet back into each launch's escrow.
PUMPPORTAL_API_KEY=your-pumpportal-api-key
PUMPPORTAL_CUSTODIAL_WALLET=your-pumpportal-wallet-public-key
PUMPPORTAL_CUSTODIAL_PRIVATE_KEY=your-pumpportal-wallet-private-key-bs58

# Erys platform wallet — funds sponsored launch escrows asynchronously.
# Same value as the Supabase secret of the same name. Base58-encoded
# Solana secret key (64-byte ed25519 expanded key).
ERYS_PLATFORM_PRIVATE_KEY=your-platform-wallet-private-key-bs58

# NOTE: The executor confirms its own custodial-wallet transactions via
# HTTP polling (getSignatureStatuses) with blockhash-refresh retries, so any
# Solana RPC tier works — WebSocket / signatureSubscribe support is NOT
# required. You may see harmless "Method 'signatureSubscribe' not found"
# warnings from web3.js internals on RPCs without WS; ignore them.