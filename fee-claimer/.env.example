# ============================================================
# REQUIRED — service exits on boot if any of these are missing
# ============================================================

# Supabase project (same values as the distributor service)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana RPC. Any HTTP-only tier works — fee-claimer confirms its own
# transactions via getSignatureStatuses polling. No WebSocket needed.
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-key

# AES-256-GCM key (hex) used to decrypt escrow / lightning wallet secrets
# stored in the DB. Must be the SAME value as in the distributor and
# executor services and the ESCROW_ENCRYPTION_KEY Supabase secret.
ESCROW_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Treasury destination. All Pump.fun creator fees swept by the
# batched-custodial and local-signing paths land here. The per-launch
# harvest path also routes its 30% treasury share here.
BAGS_PARTNER_WALLET=your-erys-platform-wallet-public-key

# ============================================================
# REQUIRED for the BATCHED CUSTODIAL claim path (PumpPortal)
# ============================================================
# Slot 1 (legacy single-wallet env path). Additional slots can be
# configured with _2, _3, ... suffixes. The pool is also loaded from the
# Supabase `lightning_wallets` table — env values win on pubkey
# collision so behaviour is identical to the distributor.
PUMPPORTAL_API_KEY=your-pumpportal-api-key
PUMPPORTAL_CUSTODIAL_WALLET=your-pumpportal-wallet-public-key
PUMPPORTAL_CUSTODIAL_PRIVATE_KEY=your-pumpportal-wallet-private-key-bs58

# Optional additional pool slots:
# PUMPPORTAL_API_KEY_2=
# PUMPPORTAL_CUSTODIAL_WALLET_2=
# PUMPPORTAL_CUSTODIAL_PRIVATE_KEY_2=

# ============================================================
# OPTIONAL — tuning + multi-replica identity
# ============================================================

# Unique worker identifier for SKIP LOCKED row claiming. Falls back to
# RAILWAY_REPLICA_ID automatically — only set when running outside Railway
# or to give a replica a stable name in logs.
# WORKER_ID=fee-claimer-1

# Batched custodial path: how many launches per claim cycle.
# PUMPFUN_FEE_BATCH_SIZE=50

# Local-signing path: how many launches per cycle.
# PUMPFUN_LOCAL_CLAIM_BATCH_SIZE=10

# Skip claims when the on-chain creator vault holds less than this many
# lamports (~10× the per-cycle gas cost). Hard floor of 100,000 lamports
# is enforced regardless of this setting.
# PUMPFUN_MIN_CLAIM_LAMPORTS=600000

# Per-launch harvest gas estimate + minimum-claim multiplier.
# Vault must hold >= GAS_ESTIMATE * MIN_MULTIPLIER lamports to harvest.
# PER_LAUNCH_HARVEST_GAS_ESTIMATE_LAMPORTS=110000
# PER_LAUNCH_MIN_HARVEST_MULTIPLIER=10

# Pump program ID (mainnet). Override only if Pump.fun ever migrates.
# PUMP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P