SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-key
ESCROW_ENCRYPTION_KEY=your-32-byte-hex-encryption-key
BAGS_PARTNER_WALLET=your-erys-platform-wallet-public-key
POLL_INTERVAL_MS=30000
# Optional unique worker identifier for distributed locking. Falls back to
# RAILWAY_REPLICA_ID automatically — only set this when running outside Railway.
# WORKER_ID=worker-1

# Pump.fun fee-claim economics. Default skips claims when the on-chain
# creator vault holds less than 600,000 lamports (~10x the per-cycle cost).
# Hard floor of 100,000 lamports is enforced regardless of this setting.
# PUMPFUN_MIN_CLAIM_LAMPORTS=600000

# Pump program ID (mainnet). Override only if Pump.fun ever migrates.
# PUMP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
